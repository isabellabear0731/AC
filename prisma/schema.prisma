generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}

model User {
  id                      String                   @id @default(cuid())
  email                   String                   @unique
  passwordHash            String
  firstName               String
  lastName                String
  phone                   String?
  role                    Role
  isActive                Boolean                  @default(true)
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  emailVerified           Boolean                  @default(false)
  editedAttendances       Attendance[]             @relation("AttendanceEditor")
  teachingSessions        CourseSession[]          @relation("TeacherSessions")
  uploadedResources       TeachingResource[]       @relation("UploadedResources")
  receivedMessages        Message[]                @relation("MessageReceiver")
  sentMessages            Message[]                @relation("MessageSender")
  notifications           Notification[]
  children                StudentProfile[]         @relation("ParentStudents")
  studentProfile          StudentProfile?
  teacherComments         TeacherComment[]         @relation("TeacherComments")
  passwordResetTokens     PasswordResetToken[]
  emailVerificationTokens EmailVerificationToken[]
  auditLogs               AuditLog[]
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model EmailVerificationToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model StudentProfile {
  id               String    @id @default(cuid())
  studentUserId    String    @unique
  parentId         String?
  dateOfBirth      DateTime?
  notes            String?
  emergencyContact String?
  medicalNotes     String?

  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  attendance    Attendance[]
  registrations Registration[]
  parent        User?            @relation("ParentStudents", fields: [parentId], references: [id])
  studentUser   User             @relation(fields: [studentUserId], references: [id])
  comments      TeacherComment[]
}

model Course {
  id String @id @default(cuid())

  title       String
  description String?
  categoryId  String?
  category    CourseCategory? @relation(fields: [categoryId], references: [id])
  price       Float

  location String?
  isActive Boolean @default(true)

  capacity Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sessions CourseSession[]
}

model CourseCategory {
  id        String  @id @default(cuid())
  name      String  @unique
  color     String?
  sortOrder Int     @default(0)
  isActive  Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  courses Course[]
}

model CourseSession {
  id                String             @id @default(cuid())
  courseId          String
  title             String?
  startTime         DateTime
  endTime           DateTime
  teacherId         String?
  weekday           Weekday?
  displayOrder      Int                @default(0)
  capacityOverride  Int?
  isCancelled       Boolean            @default(false)
  teacher           User?              @relation("TeacherSessions", fields: [teacherId], references: [id])
  notes             String?
  room              String?
  createdAt         DateTime           @default(now())
  attendance        Attendance[]
  course            Course             @relation(fields: [courseId], references: [id])
  registrations     Registration[]
  teachingResources TeachingResource[]
}

model Registration {
  id           String             @id @default(cuid())
  studentId    String
  sessionId    String
  status       RegistrationStatus @default(PENDING)
  cancelReason String?
  approvedAt   DateTime?
  createdAt    DateTime           @default(now())
  payment      Payment?
  session      CourseSession      @relation(fields: [sessionId], references: [id])
  student      StudentProfile     @relation(fields: [studentId], references: [id])

  @@unique([studentId, sessionId])
}

model Attendance {
  id        String           @id @default(cuid())
  studentId String
  sessionId String
  status    AttendanceStatus @default(PENDING)

  checkInTime   DateTime?
  checkOutTime  DateTime?
  arrivalNote   String?
  departureNote String?
  reason        String?

  editedById String?
  createdAt  DateTime       @default(now())
  editedBy   User?          @relation("AttendanceEditor", fields: [editedById], references: [id])
  session    CourseSession  @relation(fields: [sessionId], references: [id])
  student    StudentProfile @relation(fields: [studentId], references: [id])

  @@unique([studentId, sessionId])
}

model TeacherComment {
  id        String         @id @default(cuid())
  studentId String
  teacherId String
  comment   String
  createdAt DateTime       @default(now())
  student   StudentProfile @relation(fields: [studentId], references: [id])
  teacher   User           @relation("TeacherComments", fields: [teacherId], references: [id])
}

model TeachingResource {
  id               String         @id @default(cuid())
  sessionId        String?
  uploadedById     String
  title            String
  description      String?
  fileUrl          String
  mimeType         String
  resourceType     ResourceType
  visibleToStudent Boolean        @default(true)
  visibleToParent  Boolean        @default(true)
  createdAt        DateTime       @default(now())
  session          CourseSession? @relation(fields: [sessionId], references: [id])
  uploadedBy       User           @relation("UploadedResources", fields: [uploadedById], references: [id])
}

model Message {
  id         String   @id @default(cuid())
  senderId   String
  receiverId String
  content    String
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())
  receiver   User     @relation("MessageReceiver", fields: [receiverId], references: [id])
  sender     User     @relation("MessageSender", fields: [senderId], references: [id])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id])
}

model Payment {
  id             String        @id @default(cuid())
  registrationId String        @unique
  amount         Float
  status         PaymentStatus @default(UNPAID)
  paidAt         DateTime?
  createdAt      DateTime      @default(now())
  registration   Registration  @relation(fields: [registrationId], references: [id])
}

model AuditLog {
  id String @id @default(cuid())

  actorId String?
  actor   User?   @relation(fields: [actorId], references: [id])

  action String

  entityType String
  entityId   String

  description String?

  before Json?
  after  Json?

  ipAddress String?
  userAgent String?

  createdAt DateTime @default(now())

  @@index([actorId])
  @@index([entityType])
  @@index([entityId])
  @@index([createdAt])
}

enum Role {
  PARENT
  STUDENT
  ADULT
  TEACHER
  ADMIN
}

enum RegistrationStatus {
  PENDING
  APPROVED
  CANCELLED
  REJECTED
  WAITLISTED
}

enum PaymentStatus {
  UNPAID
  PAID
}

enum NotificationType {
  EMAIL
  SMS
  MESSAGE
  REGISTRATION
  PAYMENT
}

enum AttendanceStatus {
  PRESENT
  LATE
  EXCUSED_ABSENT
  UNEXCUSED_ABSENT
  PENDING
}

enum ResourceType {
  MATERIAL
  PHOTO
  EVALUATION
}

enum Weekday {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}
